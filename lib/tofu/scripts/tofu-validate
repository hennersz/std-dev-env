#! /usr/bin/env bash
set -euo pipefail

found=0
while IFS= read -r main; do
	found=1
	mod=$(dirname "$main")
	echo "Validating ${mod}..."
	(cd "$mod" && tofu init -backend=false -reconfigure -input=false >/dev/null && tofu validate)
done < <(find . -name 'main.tf' -not -path '*/.git/*' -not -path '*/.terraform/*')

if [[ $found -eq 0 ]]; then
	echo "No main.tf files found"
fi
