#!/usr/bin/env bash
set -euo pipefail

repo_root="${DEVENV_ROOT:-${REPO_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}}"
templates_dir="${repo_root}/templates"

shopt -s nullglob
templates=("${templates_dir}"/*/)
if ((${#templates[@]} == 0)); then
	echo "no templates found in ${templates_dir}" >&2
	exit 1
fi

for dir in "${templates[@]}"; do
	template=$(basename "$dir")

	echo "==> testing template: ${template}"
	tmpdir=$(mktemp -d)
	trap 'rm -rf "${tmpdir:?}"' EXIT

	cd "$tmpdir"
	nix flake init -t "path:${repo_root}#${template}"

	nix develop --no-pure-eval \
		--override-input std-dev-env "path:${repo_root}" \
		-c check

	cd - >/dev/null
	trap - EXIT
	rm -rf "$tmpdir"
done

echo "all templates passed"
